# AI Buddy — Environment Variables
# Copy this file to .env and fill in your values

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# AI Provider: "gemini", "openai", or "ollama"
AI_PROVIDER=gemini

# OpenAI (optional, if using OpenAI instead)
# OPENAI_API_KEY=your_openai_key_here

# Ollama (optional, if using local Ollama)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# TTS Voice (Microsoft Edge TTS)
# List voices: edge-tts --list-voices
TTS_VOICE=en-US-GuyNeural

# Whisper model size: tiny, base, small, medium, large
# Smaller = faster but less accurate
WHISPER_MODEL=base

# Server settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# Personality: snarky, friendly, professional
PERSONALITY=snarky
